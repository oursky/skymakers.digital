---
const currentPath = Astro.url.pathname;
---

<div
  data-animation="default"
  data-collapse="medium"
  data-duration="400"
  data-easing="ease"
  data-easing2="ease"
  role="banner"
  class="navbar-2 dark w-nav"
>
  <div class="container-nev w-container">
    <div class="nav-logo__container">
      <a href="/" class="nav-logo-link w-nav-brand">
        <img
          src="/images/664b2cdac6e8957fff048fce_Skymakers_dark.png"
          loading="lazy"
          alt="Skymakers"
          class="nav-logo"
        />
      </a>
      <a href="/" class="nav-logo-link nav-logo-link--blue w-nav-brand">
        <img
          src="/images/664f50313aa98a7049a32bd2_Skymakers_light.png"
          loading="lazy"
          alt="Skymakers"
          class="nav-logo"
        />
      </a>
    </div>
    <nav role="navigation" class="nav-menu w-nav-menu">
      <a href="/" class:list={['nav-link', 'w-nav-link', { 'w--current': currentPath === '/' }]}>Home</a>
      <div data-hover="false" data-delay="0" class="dropdown w-dropdown">
        <nav class="dropdown-list mobile w-dropdown-list">
          <a href="https://www.formx.ai/" target="_blank" class="dropdown-link w-dropdown-link">FormX.ai</a>
          <a href="https://www.authgear.com/" target="_blank" class="dropdown-link-2 w-dropdown-link">Authgear</a>
          <a href="https://www.oursky.com/" target="_blank" class="dropdown-link-3 w-dropdown-link">Oursky</a>
        </nav>
      </div>
      <a href="https://jobs.oursky.com" class="nav-link w-nav-link">Jobs</a>
      <a href="/contact" class:list={['nav-link', 'w-nav-link', { 'w--current': currentPath === '/contact/' }]}>Contact</a>
    </nav>
    <div class="menu-button-2 dark w-nav-button">
      <div class="burger dark w-icon-nav-menu"></div>
    </div>
  </div>
</div>

<style>
  @media screen and (max-width: 991px) {
    .nav-menu.w--open {
      display: block !important;
      top: 100%;
      left: 0;
      right: 0;
      width: 100%;
    }
    .dropdown-list.w--open {
      overflow: visible;
      max-height: none;
    }
  }
</style>
