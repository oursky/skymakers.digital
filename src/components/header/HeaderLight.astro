---
const currentPath = Astro.url.pathname;
---

<div
  role="banner"
  class="navbar-light w-nav"
  data-collapse="medium"
>
  <div class="container-nev light w-container">
    <a href="/" class="link-block-2 w-inline-block">
      <img
        src="/images/664f50313aa98a7049a32bd2_Skymakers_light.png"
        loading="lazy"
        alt="Skymakers"
        class="image-18"
      />
    </a>
    <nav role="navigation" class="nav-menu w-nav-menu">
      <a href="/" class:list={['nav-link', 'light', 'w-nav-link', { 'w--current': currentPath === '/' }]}>Home</a>
      <a href="https://jobs.oursky.com" class="nav-link light w-nav-link">Jobs</a>
      <a href="/contact" class:list={['nav-link', 'light', 'w-nav-link', { 'w--current': currentPath === '/contact/' }]}>Contact</a>
    </nav>
    <div class="menu-button-2 light w-nav-button" aria-expanded="false" aria-label="Toggle navigation">
      <div class="burger w-icon-nav-menu"></div>
    </div>
  </div>
</div>

<style>
  @media screen and (max-width: 991px) {
    .nav-menu.w--open {
      display: block !important;
      top: 100%;
      left: 0;
      right: 0;
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function () {
    var nav = document.querySelector('.navbar-light');
    if (!nav) return;
    var burger = nav.querySelector('.w-nav-button');
    var menu = nav.querySelector('.w-nav-menu');

    burger && burger.addEventListener('click', function () {
      var open = menu.classList.toggle('w--open');
      burger.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
