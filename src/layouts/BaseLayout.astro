---
interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  canonical?: string;
  bodyClass?: string;
  wfPageId?: string;
  pageScript?: string;
}
const {
  title,
  description,
  ogTitle,
  ogImage,
  canonical,
  bodyClass = '',
  wfPageId = '',
  pageScript,
} = Astro.props;

const WF_SITE = '664b2a26dc3a674161d77838';
const siteUrl = 'https://www.skymakers.digital';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html data-wf-domain="www.skymakers.digital" data-wf-page={wfPageId} data-wf-site={WF_SITE} lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    {ogTitle && <meta property="og:title" content={ogTitle} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Favicons -->
    <link href="/images/665838b758782597bd3bf70a_SkyMakers_Digital_fav_32x32.png" rel="shortcut icon" type="image/x-icon" />
    <link href="/images/665838a413e86b4a42620c4f_SkyMakers_Digital_Webclip_256x256.png" rel="apple-touch-icon" />

    <!-- Webflow CSS (self-hosted) -->
    <link href="/styles/webflow.css" rel="stylesheet" type="text/css" />

    <!-- Google Fonts (non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@300;400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Webflow JS detection (adds w-mod-js / w-mod-touch classes) -->
    <script is:inline>
      !function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);
    </script>

    <!-- Plausible Analytics (privacy-friendly, no consent needed) -->
    <script defer data-domain="skymakers.digital" src="https://plausible.io/js/script.js"></script>
  </head>

  <body class={bodyClass}>
    <slot />

    <!-- jQuery + Webflow JS (self-hosted) -->
    <script is:inline src="/js/jquery-3.5.1.min.js"></script>
    <script is:inline src="/js/webflow.schunk.0352c34bcabb015d.js"></script>
    <script is:inline src="/js/webflow.schunk.d0b0b4e5f689b8bd.js"></script>
    {pageScript && <script is:inline src={pageScript}></script>}
  </body>
</html>
