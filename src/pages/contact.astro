---
import PageLayout from '@/layouts/PageLayout.astro';
const content = `<section class="page_section"><div class="w-layout-blockcontainer _1096 w-container"><div class="w-layout-grid grid-3"><div data-w-id="f54b1afb-9ea9-b9ba-62af-6facedc229de" style="opacity:0" class="product_hero-info-text"><h1 class="l-h1 left">Connect with SkyMakers: <span class="text-span">Let&#x27;s Make Magic Together!</span></h1><p class="paragraph_18">Whether you&#x27;re a fellow digital wizard seeking collaboration, a curious mind with innovative ideas, or simply a cat enthusiast in need of feline friends, we&#x27;d love to hear from you! So, grab your broomstick, hop on your unicorn, or just send a good old-fashioned email, and let&#x27;s connect!</p></div><img src="/images/665e8f902822091301cb4693_Leisure Room 2 (1).jpg" loading="lazy" id="w-node-_8d26db9e-e71a-ffd3-c3d8-ab6448895e47-c784e241" sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 940px" alt="" srcset="/images/665e8f902822091301cb4693_Leisure Room 2 (1)-p-500.jpg 500w, /images/665e8f902822091301cb4693_Leisure Room 2 (1)-p-800.jpg 800w, /images/665e8f902822091301cb4693_Leisure Room 2 (1)-p-1080.jpg 1080w, /images/665e8f902822091301cb4693_Leisure Room 2 (1)-p-1600.jpg 1600w, /images/665e8f902822091301cb4693_Leisure Room 2 (1)-p-2000.jpg 2000w, /images/665e8f902822091301cb4693_Leisure Room 2 (1).jpg 2471w" class="contact_hero_img"/></div></div></section><section class="page_section"><div class="w-layout-blockcontainer _1096 _w-100 w-container"><div class="gap-32-wrap"><h1 class="l-h2 center">Work with us</h1><div class="contact-form-block w-form">
        <form
          id="contact-form"
          name="contact"
          netlify
          data-netlify-honeypot="bot-field"
          data-netlify-recaptcha="true"
          method="post"
          class="contact-form"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p hidden><input name="bot-field" /></p>
          <div class="contact-form-fieldset">
            <input class="contact-form-field w-input" maxlength="256" name="name" placeholder="Name" type="text" id="Name" required/>
            <input class="contact-form-field w-input" maxlength="256" name="Company" placeholder="Company" type="text" id="Company" required/>
          </div>
          <input class="contact-form-field w-input" maxlength="256" name="Email" placeholder="Email" type="email" id="Email" required/>
          <textarea required placeholder="What do you want to build?" maxlength="5000" id="Notes-2" name="Notes" class="contact-form-field text-area w-input"></textarea>
          <div data-netlify-recaptcha="true"></div>
          <input type="submit" class="contact-form-submit w-button" value="Let&#x27;s Talk"/>
        </form>
        <div class="contact-form-success w-form-done"><div>Thank you! Your submission has been received!</div></div>
        <div class="w-form-fail"><div>Oops! Something went wrong while submitting the form.</div></div>
      </div></div></div><div class="paragraph_18 center contact_line-height-36 contact-us-subtext">or contact us via <a target="_blank" href="mailto:hello@skymakers.digital">hello@skymakers.digital</a>.<br/>❤️ We aim to get back to you in about 2 business days.</div></div></div></section><section class="page_section bg-gray"><div class="w-layout-blockcontainer _1096 w-container"><div class="gap-40-wrap"><div class="center__tagline"><h1 class="l-h2 center">Where the Magic Happens</h1></div><div class="w-layout-grid contact-card-wrap"><div data-w-id="e72a67cd-f88e-f529-8efb-fa14dbb21b3f" style="opacity:0" class="contact-card"><h1 class="s-h2">🇬🇧</h1><h1 class="s-h2">Greater Manchester</h1><div class="contact-text"><img src="/images/6655dd9779a9dad185ea3a20_location_on.png" loading="lazy" alt="" class="image-19"/><p class="paragraph_18">SkyMakers Digital Limited, Bank Chambers, St. Petersgate, Stockport, SK1 1AR, United Kingdom</p></div><div class="contact-text"><img src="/images/6655dda43951aba720fd295e_phone_enabled.png" loading="lazy" alt="" class="image-20"/><p class="paragraph_18">+44 16 1818 8339</p></div></div><div data-w-id="bf088055-8236-5d0f-6c7a-1f89480c9df4" style="opacity:0" class="contact-card"><h1 class="s-h2">🇭🇰</h1><h1 class="s-h2">Hong Kong</h1><div><div class="contact-link"><img src="/images/6655dd9779a9dad185ea3a20_location_on.png" loading="lazy" alt="" class="image-19"/><p class="paragraph_18">Rm B, 10/F, Great Wall Factory Bldg, 11 Cheung Shun St, Cheung Sha Wan, Hong Kong (Lai Chi Kok MTR Exit D2)</p></div></div><div class="contact-text"><img src="/images/6655dda43951aba720fd295e_phone_enabled.png" loading="lazy" alt="" class="image-20"/><p class="paragraph_18">+852 2155 9299</p></div><div class="contact-text"><img src="/images/6655de15221f3c4a98988095_fax.png" loading="lazy" alt="" class="image-20"/><p class="paragraph_18">+852 3020 0215</p></div></div><div data-w-id="6ca7648c-6427-561c-d57c-87ae9bdc5388" style="opacity:0" class="contact-card"><h1 class="s-h2">🇹🇼</h1><h1 class="s-h2">Taipei</h1><div class="contact-link"><img src="/images/6655dd9779a9dad185ea3a20_location_on.png" loading="lazy" alt="" class="image-19"/><p class="paragraph_18">6F.-2, No. 666, Sec. 4, Bade Rd., Songshan Dist.,<br/>Taipei City 105057, Taiwan</p></div><div class="contact-text"><img src="/images/6655dda43951aba720fd295e_phone_enabled.png" loading="lazy" alt="" class="image-20"/><p class="paragraph_18">+886 2 2712 0059</p></div></div><div data-w-id="e75e2373-ecbd-013c-ef10-a2158da1f823" style="opacity:0" class="contact-card"><h1 class="s-h2">🇯🇵</h1><h1 class="s-h2">Tokyo</h1><div class="contact-text"><img src="/images/6655dd9779a9dad185ea3a20_location_on.png" loading="lazy" alt="" class="image-19"/><p class="paragraph_18">東京都渋谷区神宮前六丁目23番4号桑野ビル2階</p></div></div></div></div></div></section>`;
---

<PageLayout
  title="Contact"
  description="Connect with SkyMakers. Whether you're looking to collaborate or have a project in mind, we'd love to hear from you."
  navVariant="light"
  wfPageId="6655d82cd36d1b61c784e241"
  pageScript="/js/webflow.5f5553c5.67307008fe65e7cc.js"
>
  <Fragment set:html={content} />
</PageLayout>

<script is:inline>

(function() {
  var formEl = document.querySelector('#contact-form');
  if (!formEl) return;
  formEl.addEventListener('submit', function(e) {
    e.preventDefault();
    var wform = formEl.closest('.w-form');
    var done  = wform && wform.querySelector('.w-form-done');
    var fail  = wform && wform.querySelector('.w-form-fail');
    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(formEl)).toString()
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Network response was not ok');
      formEl.style.display = 'none';
      if (done) done.style.display = 'block';
    })
    .catch(function() {
      if (fail) fail.style.display = 'block';
    });
  });
})();

</script>
