const content = `<section class="home-hero-section"><div class="hero-wrap"><div data-fade-in class="hero__container"><h1 class="l-h1">Engineering excellence is the baseline here</h1><p class="paragraph_18 white">We enable business to transform in the digital world while enhancing and protecting users&#x27; security and privacy</p><a href="/contact" class="btn-white w-button">Contact Us</a></div><div class="div-block-14"></div><div class="background-video-2 w-background-video w-background-video-atom"><video autoplay="" loop="" style="background-image:url('/videos/69c390c766f89d279224aa36_Veo_3_1_Flags_moves_poster.jpg')" muted="" playsinline=""><source src="/videos/69c390c766f89d279224aa36_Veo_3_1_Flags_moves_mp4.mp4"/><source src="/videos/69c390c766f89d279224aa36_Veo_3_1_Flags_moves_webm.webm"/></video></div></div></section><section class="page_section hidden"><div data-fade-in class="feature__container"><div class="w-layout-grid feature_grid"><div class="feature-img-div"><img src="/images/66544e58180051dab856c18c_Discussion 2 (1).jpg" loading="eager" sizes="(max-width: 2560px) 100vw, 2560px" srcset="/images/66544e58180051dab856c18c_Discussion 2 (1)-p-500.jpg 500w, /images/66544e58180051dab856c18c_Discussion 2 (1)-p-800.jpg 800w, /images/66544e58180051dab856c18c_Discussion 2 (1)-p-1080.jpg 1080w, /images/66544e58180051dab856c18c_Discussion 2 (1)-p-1600.jpg 1600w, /images/66544e58180051dab856c18c_Discussion 2 (1)-p-2000.jpg 2000w, /images/66544e58180051dab856c18c_Discussion 2 (1).jpg 2560w" alt="" class="featurerow__image"/></div><div class="feature_desc"><h1 class="l-h2">Build a better world with code</h1><p class="paragraph_18">SkyMakers revolutionizes software development by delivering value-added services that seamlessly enhance your core products, providing an elevated user experience while eliminating technical intricacies.</p></div></div></div></section><section class="page_section"><div class="center__tagline"><h2 class="l-h2 center">Solutions for more usable and secure applications</h2><p class="paragraph_18 center">We provide developers with the right software, API, training and professional services to develop more usable and secure customer-facing applications easily.</p></div><div class="solution__cards__wrapper"><div class="w-layout-grid solution_grid"><a data-fade-in href="https://www.formx.ai/" target="_blank" class="clickable_cards w-inline-block"><img src="/images/664c71444af09d10bbd46300_FromX_logo_card.png" loading="eager" sizes="(max-width: 608px) 100vw, 608px" srcset="/images/664c71444af09d10bbd46300_FromX_logo_card-p-500.png 500w, /images/664c71444af09d10bbd46300_FromX_logo_card.png 608w" alt="" class="clickable_cards_img"/><h3 class="clickable_cards_title">FormX.ai</h3><p class="clickable_cards_info">Empower Your Team with AI: Eliminate Manual Work, Embrace Seamless Automation!</p><div class="clickable-cards-learn-more"><p class="clickable_text">Learn more</p><img src="/images/664c6e48509cf3239d4b1588_arrow_forward.png" loading="lazy" alt="" class="img_arrow"/></div></a><a data-fade-in href="https://www.authgear.com/" target="_blank" class="clickable_cards w-inline-block"><img src="/images/664c714464b3594f68fcd315_Authgear_card_logo.png" loading="eager" sizes="(max-width: 608px) 100vw, 608px" srcset="/images/664c714464b3594f68fcd315_Authgear_card_logo-p-500.png 500w, /images/664c714464b3594f68fcd315_Authgear_card_logo.png 608w" alt="" class="clickable_cards_img"/><h3 class="clickable_cards_title">Authgear</h3><p class="clickable_cards_info">Activate Security with Auth, Simple and Scalable for Your Business.</p><div class="clickable-cards-learn-more"><p class="clickable_text">Learn more</p><img src="/images/664c6e48509cf3239d4b1588_arrow_forward.png" loading="lazy" alt="" class="img_arrow"/></div></a><a data-fade-in href="https://www.oursky.com/" target="_blank" class="clickable_cards w-inline-block"><img src="/images/664c71447a237cee7064bb1c_Oursky_card_Logo.png" loading="eager" sizes="(max-width: 608px) 100vw, 608px" srcset="/images/664c71447a237cee7064bb1c_Oursky_card_Logo-p-500.png 500w, /images/664c71447a237cee7064bb1c_Oursky_card_Logo.png 608w" alt="" class="clickable_cards_img"/><h3 class="clickable_cards_title">Oursky</h3><p class="clickable_cards_info">World-class Software Development Company with Clients Across the Globe.</p><div class="clickable-cards-learn-more"><p class="clickable_text">Learn more</p><img src="/images/664c6e48509cf3239d4b1588_arrow_forward.png" loading="lazy" alt="" class="img_arrow"/></div></a></div></div></section><section class="page_section bg-gray"><div class="w-layout-blockcontainer logo__container w-container"><div class="center__tagline"><h1 class="l-h2 center">Trusted by Leaders: Skymakers&#x27; Esteemed Clientele</h1><p class="paragraph_18 center">Explore the elite list of industry leaders who trust Skymakers for exceptional software development. Join the ranks of businesses that have chosen excellence with Skymakers.</p></div><div class="w-layout-grid client_logo_grid"><div><img src="/images/664cb67642532d1949b00d8c_Swire Propertimes.png" loading="eager" alt=""/></div><div><img src="/images/664cb6774465ab236f9c2cbd_MTR.png" loading="eager" alt=""/></div><div><img src="/images/664cb676d3257347f229c255_WeLab Bank.png" loading="eager" alt=""/></div><div><img src="/images/664cb676eea0d2e94fb4d4c7_Asos.png" loading="eager" alt=""/></div><div><img src="/images/664cb67677613065821aefc0_Axiata.png" loading="eager" alt=""/></div><div><img src="/images/664cb676169130b0f1db1243_Plaza.png" loading="eager" alt=""/></div><div><img src="/images/664cb67673b4b2190dbdc357_Socket.png" loading="eager" alt=""/></div><div><img src="/images/664cb6765f017b67bc65895d_Thomson.png" loading="eager" alt=""/></div><div><img src="/images/664cb676544242f9ff6668ee_TaTa.png" loading="eager" alt=""/></div><div><img src="/images/664cb6763cbe87097252a458_HKTDC.png" loading="eager" alt=""/></div><div><img src="/images/664cb676bde2d2c316e0669e_milwaukee.png" loading="eager" alt=""/></div><div><img src="/images/664cb676d65074128c17f752_Standard.png" loading="eager" alt=""/></div><div><img src="/images/664cb676eeded5d6c9ce2f29_Philips.png" loading="eager" alt=""/></div><div><img src="/images/664cb676a7b4650d8dbbed62_Likecoin.png" loading="eager" alt=""/></div><div><img src="/images/664cb67679aaac5a6aa20b23_K11.png" loading="eager" alt=""/></div><div><img src="/images/664cb676d1b7599242f8070b_Wilson.png" loading="eager" alt=""/></div><div></div><div></div><div></div><div></div><div></div><div></div></div></div></section>`;
